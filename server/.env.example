# ── Server ────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Authentication ────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_COST_FACTOR=12

# ── MongoDB ───────────────────────────────
# Leave unset to auto-start a persistent local embedded MongoDB (see server/src/config/db.ts).
# Set this to use a real instance instead (Atlas, staging, etc).
# MONGODB_URI=

# ── Redis (BullMQ specialist job queues) ──
# Leave unset to auto-start an in-memory Redis for local dev (see server/src/queues/redis.ts).
# Set this to use a real instance instead (Docker, ElastiCache, staging, etc).
# REDIS_URL=

# ── Google AI / ADK ───────────────────────
ADK_AGENT_URL=http://localhost:8001
